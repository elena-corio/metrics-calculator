{
  "program_types": {
    "Living": { "is_green": false, "is_usable": true },
    "Working": { "is_green": false, "is_usable": true },
    "Learning": { "is_green": false, "is_usable": true },
    "Commerce": { "is_green": false, "is_usable": true },
    "Leisure": { "is_green": false, "is_usable": true },
    "Health": { "is_green": false, "is_usable": true },
    "Community": { "is_green": true, "is_usable": true },
    "Circulation": { "is_green": false, "is_usable": false},
    "Support": { "is_green": false, "is_usable": false }
  },
  "material_types": {
    "Concrete": { "is_transparent": false, "density": 2400, "carbon_factor": 0.12 },
    "Steel": { "is_transparent": false, "density": 7850, "carbon_factor": 2.0 },
    "Timber": { "is_transparent": false, "density": 500, "carbon_factor": 0.5 },
    "Glass": { "is_transparent": true, "density": 2500, "carbon_factor": 1.6 },
    "Plastic": { "is_transparent": false, "density": 1200, "carbon_factor": 2.5 }
  },
  "metrics":{
    "daylight_potential": {
      "benchmark": 0.25,
      "formula": "window_area / net_floor_area"
    },
    "green_space_index": {
      "benchmark": 0.80,
      "target": 300,
      "formula": "max (0, 1 - distance_to_green / target)"
    },
    "program_diversity_index": {
      "benchmark": 0.75,
      "formula": "1 - (program_frequencies / program_units_count²)"
    },
    "circulation_efficiency": {
      "benchmark": 0.75,
      "formula": "1 - (circulation_area / total_area)"
    },
    "occupancy_efficiency": {
      "benchmark": 0.70,
      "formula": "usable_area / total_area"
    },
    "net_floor_area_ratio": {
      "benchmark": 0.85,
      "formula": "net_floor_area / gross_floor_area"
    },
    "surface_to_volume_ratio": {
      "benchmark": 0.60,
      "formula": "building_volume / envelope_area"
    },
    "carbon_efficiency": {
      "benchmark": 0.50,
      "target": 600,
      "formula": "max (0, 1 - embodied_carbon_intensity / target)"
    }
}
}